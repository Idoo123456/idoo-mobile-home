<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8FB"
    android:padding="24dp"
    tools:context=".Pertemuan_2.SecondActivity">

    <ImageView
        android:id="@+id/imgCute"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_launcher_foreground"
        android:tint="#FF8FC1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/textNama"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textNama"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌸 Welcome 🌸"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FF6FAF"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/imgCute"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/mainCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/textNama"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <EditText
                android:id="@+id/inputNama"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#FFEAF4"
                android:hint="Masukkan Nama"
                android:padding="14dp"
                android:textColor="#444444"
                android:textColorHint="#FF9CC4"
                android:inputType="textPersonName"/>

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:text="Submit"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#FF8FC1"/>

            <TextView
                android:id="@+id/textHasil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Hasil akan muncul di sini ✨"
                android:textSize="18sp"
                android:textColor="#FF6FAF"
                android:textStyle="bold"
                android:layout_marginTop="25dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>